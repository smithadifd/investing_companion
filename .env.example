# ===========================================
# Investing Companion - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Database
# ===========================================
POSTGRES_USER=investing
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=investing_companion

# ===========================================
# Application
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# development, staging, production
ENVIRONMENT=development

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ===========================================
# External API Keys
# ===========================================
# Alpha Vantage (free tier available)
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Polygon.io (optional, paid tier for real-time)
# Get key at: https://polygon.io/
POLYGON_API_KEY=

# Finnhub (news data - free tier, 60 req/min)
# Get key at: https://finnhub.io/register
FINNHUB_API_KEY=

# ===========================================
# Notifications
# ===========================================
# Discord webhook URL for alerts
# Create at: Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# ===========================================
# AI Integration
# ===========================================
# Note: Claude API key is stored per-user in the database
# This is a fallback/default key for development
CLAUDE_API_KEY=

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# Frontend
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
