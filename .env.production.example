# =============================================================================
# Investing Companion - Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and update all values before deployment
#
# IMPORTANT: Never commit .env.production to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED SETTINGS (must be changed from defaults)
# -----------------------------------------------------------------------------

# Domain name for your deployment (e.g., invest.example.com)
DOMAIN=invest.yourdomain.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# Secret key for JWT tokens - MUST be changed!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_32_char_minimum_key

# Database credentials - MUST be changed from defaults!
POSTGRES_USER=investing_prod
POSTGRES_PASSWORD=CHANGE_ME_generate_secure_password
POSTGRES_DB=investing_companion

# -----------------------------------------------------------------------------
# OPTIONAL SETTINGS (can keep defaults or customize)
# -----------------------------------------------------------------------------

# Registration settings
# Set to false to disable new user registration (single-user mode)
REGISTRATION_ENABLED=false

# Discord webhook for alerts (optional - alerts still work, just no Discord)
DISCORD_WEBHOOK_URL=

# Claude API key for AI features (optional - users can add their own in settings)
CLAUDE_API_KEY=

# Alpha Vantage API key for additional market data (optional)
# Free tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Polygon.io API key for real-time data (optional, paid service)
POLYGON_API_KEY=

# -----------------------------------------------------------------------------
# ADVANCED SETTINGS (usually don't need to change)
# -----------------------------------------------------------------------------

# Environment identifier
ENVIRONMENT=production

# CORS origins (should match your domain with HTTPS)
# CORS_ORIGINS=https://invest.yourdomain.com

# JWT token lifetimes
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Cache TTLs (in seconds)
# QUOTE_CACHE_TTL=900
# FUNDAMENTALS_CACHE_TTL=86400
# HISTORY_CACHE_TTL=3600


# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
# Before deploying, verify:
#
# [ ] DOMAIN is set to your actual domain
# [ ] ACME_EMAIL is your real email for Let's Encrypt
# [ ] SECRET_KEY is a unique, secure 32+ character string
# [ ] POSTGRES_PASSWORD is secure (16+ characters, mixed case, numbers, symbols)
# [ ] DNS is configured to point your domain to your Synology
# [ ] Ports 80 and 443 are forwarded to your Synology (for Let's Encrypt)
# [ ] .env.production is NOT committed to git
#
# To deploy:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# =============================================================================
